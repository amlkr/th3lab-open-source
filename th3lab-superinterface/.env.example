# MCP HTTP endpoint (TH3LAB)
# Puedes pasar una sola URL o varias separadas por coma.
# Ejemplo multi-fallback:
# TH3LAB_MCP_URL=http://localhost:3000/mcp,http://localhost:3000,http://localhost:8090/mcp,http://localhost:8090
TH3LAB_MCP_URL=http://localhost:3000/mcp

# Tool name used in MCP call
TH3LAB_MCP_TOOL=chat_con_agente_principal

# Fallback adapter for current th3lab-mcp bridge (/mcp/world/ask)
TH3LAB_ASK_URL=http://localhost:8090/mcp/world/ask
TH3LAB_WORLD_ID=amniotic
TH3LAB_PROJECT_ID=_admin

# Private login
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
ENABLE_PRIVATE_LOGIN=false

# Optional Superinterface self-hosted values
NEXT_PUBLIC_SUPERINTERFACE_API_KEY=
NEXT_PUBLIC_SUPERINTERFACE_ASSISTANT_ID=
